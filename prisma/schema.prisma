generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  customer
  admin
  moderator
}

enum DesignStatus {
  pending
  completed
  failed
  moderated
}

enum OrderStatus {
  created
  payment_pending
  paid
  failed
  shipped
  completed
}

enum PaymentStatus {
  initiated
  success
  failed
}

enum ReturnStatus {
  requested
  approved
  rejected
  refunded
  escalated
}

enum SourceType {
  internal
  ai
  external
}

enum BackgroundJobType {
  ai_generation
  mockup_generation
}

enum BackgroundJobStatus {
  waiting
  active
  completed
  failed
  dead_letter
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  passwordHash   String
  role           UserRole         @default(customer)
  termsAcceptedAt DateTime
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  orders         Order[]
  designs        Design[]
  carts          Cart[]
  aiUsage        AiUsageLedger[]
  returnRequests ReturnRequest[]
}

model Supplier {
  id        String    @id @default(uuid())
  name      String
  adapter   String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id          String                 @id @default(uuid())
  name        String
  slug        String                 @unique
  type        String
  description String?
  vatRate     Decimal                @db.Decimal(5, 2)
  supplierId  String
  supplier    Supplier               @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  variants    Variant[]
  configs     ProductConfiguration[]
  orderItems  OrderItem[]
  popularityScore Int                @default(0)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([type])
  @@index([supplierId])
  @@index([popularityScore])
}

model Variant {
  id          String                 @id @default(uuid())
  productId   String
  product     Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku         String                 @unique
  size        String
  color       String
  material    String
  stock       Int                    @default(0)
  version     Int                    @default(0)
  netPrice    Decimal                @db.Decimal(10, 2)
  grossPrice  Decimal                @db.Decimal(10, 2)
  configs     ProductConfiguration[]
  orderItems  OrderItem[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([productId])
}

model Design {
  id                String                 @id @default(uuid())
  userId            String
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt            String
  normalizedPrompt  String
  promptHash        String
  imageUrl          String?
  errorMessage      String?
  sourceType        SourceType             @default(ai)
  status            DesignStatus           @default(pending)
  embedding         Unsupported("vector")?
  perceptualHash    String?
  moderatedByUserId String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  configs           ProductConfiguration[]
  moderationActions ModerationAction[]

  @@index([promptHash])
  @@index([sourceType])
}

model ProductConfiguration {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId   String
  variant     Variant   @relation(fields: [variantId], references: [id], onDelete: Restrict)
  designId    String?
  design      Design?   @relation(fields: [designId], references: [id], onDelete: SetNull)
  textOverlay String?
  previewImageUrl String?
  isValid     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@index([productId, variantId])
}

model Cart {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]

  @@index([userId, isActive])
}

model CartItem {
  id              String               @id @default(uuid())
  cartId          String
  cart            Cart                 @relation(fields: [cartId], references: [id], onDelete: Cascade)
  configurationId String
  configuration   ProductConfiguration @relation(fields: [configurationId], references: [id], onDelete: Cascade)
  quantity        Int                  @default(1)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([cartId])
}

model Order {
  id              String           @id @default(uuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  status          OrderStatus      @default(created)
  totalNet        Decimal          @db.Decimal(10, 2)
  totalVat        Decimal          @db.Decimal(10, 2)
  totalGross      Decimal          @db.Decimal(10, 2)
  currency        String           @default("PLN")
  paymentStatus   PaymentStatus    @default(initiated)
  paymentProvider String           @default("przelewy24")
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  items           OrderItem[]
  returns         ReturnRequest[]
  payments        PaymentAttempt[]
  transitionLogs  OrderTransitionLog[]

  @@index([userId, createdAt])
  @@index([deletedAt])
}

model OrderItem {
  id              String               @id @default(uuid())
  orderId          String
  order            Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId        String
  product          Product              @relation(fields: [productId], references: [id], onDelete: Restrict)
  variantId        String
  variant          Variant              @relation(fields: [variantId], references: [id], onDelete: Restrict)
  configurationId  String?
  configuration    ProductConfiguration? @relation(fields: [configurationId], references: [id], onDelete: SetNull)
  quantity         Int
  unitGross        Decimal              @db.Decimal(10, 2)
  unitVat          Decimal              @db.Decimal(10, 2)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  returnRequests   ReturnRequest[]
}

model PaymentAttempt {
  id              String        @id @default(uuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider        String
  providerRef     String?
  status          PaymentStatus @default(initiated)
  failureReason   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([providerRef])
}

model OrderTransitionLog {
  id         String      @id @default(uuid())
  orderId    String
  order      Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus OrderStatus
  toStatus   OrderStatus
  actor      String?
  reason     String?
  createdAt  DateTime    @default(now())

  @@index([orderId, createdAt])
}

model ReturnRequest {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItemId     String
  orderItem       OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  reason          String
  status          ReturnStatus  @default(requested)
  abuseScore      Int           @default(0)
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId, status])
  @@index([deletedAt])
}

model AiUsageLedger {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayKey           String
  generationsCount Int      @default(0)
  blockedCount     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, dayKey])
}

model SearchEmbedding {
  id          String                @id @default(uuid())
  sourceType  SourceType
  sourceId    String
  text        String
  embedding   Unsupported("vector")?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([sourceType, sourceId])
  @@index([sourceType, sourceId])
}

model IdempotencyRecord {
  id           String   @id @default(uuid())
  scope        String
  key          String
  requestHash  String
  responseJson Json?
  statusCode   Int?
  inFlight     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([scope, key])
  @@index([scope, createdAt])
}

model ModerationAction {
  id         String   @id @default(uuid())
  designId   String
  design     Design   @relation(fields: [designId], references: [id], onDelete: Cascade)
  moderator  String
  action     String
  reason     String?
  createdAt  DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actorRole  String?
  eventType  String
  entityType String
  entityId   String
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

model BackgroundJob {
  id            String              @id @default(uuid())
  type          BackgroundJobType
  status        BackgroundJobStatus @default(waiting)
  payload       Json
  result        Json?
  errorReason   String?
  attemptCount  Int                 @default(0)
  maxAttempts   Int                 @default(5)
  bullmqJobId   String?
  deletedAt     DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([type, status])
  @@index([status, createdAt])
}

model MockupCache {
  id         String   @id @default(uuid())
  cacheKey   String   @unique
  publicUrl  String
  productId  String
  variantId  String
  designId   String
  createdAt  DateTime @default(now())

  @@index([productId, variantId, designId])
}
